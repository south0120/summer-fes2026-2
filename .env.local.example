# Supabase プロジェクトの URL（Dashboard → Settings → API → Project URL）
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# Supabase の anon(public) キー（Dashboard → Settings → API → anon public）
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR-ANON-KEY

# Supabase の service_role キー（Dashboard → Settings → API → service_role。絶対に公開しない）
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY
